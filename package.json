{
  "name": "duffel-mcp",
  "version": "0.1.0",
  "description": "An MCP server that lets AI agents search flights and stays through the Duffel API. A developer-first replacement for Amadeus Self-Service.",
  "type": "module",
  "bin": {
    "duffel-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "MIGRATION.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "mcp-smoke": "tsx scripts/mcp-smoke.ts",
    "live-smoke": "tsx scripts/live-smoke.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "duffel",
    "flights",
    "travel",
    "amadeus",
    "ai",
    "agent",
    "llm"
  ],
  "author": "Bokang Sibolla",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bokangsibolla/duffel-mcp.git"
  },
  "homepage": "https://github.com/bokangsibolla/duffel-mcp#readme",
  "dependencies": {
    "@duffel/api": "^4.25.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
